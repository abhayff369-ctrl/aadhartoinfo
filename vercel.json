{
  "rewrites": [
    {
      "source": "/api/aadhar",
      "destination": "/api/aadhar.js"
    },
    {
      "source": "/api/aadhaar",
      "destination": "/api/aadhar.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/aadhar.js"
    }
  ],
  "functions": {
    "api/aadhar.js": {
      "maxDuration": 10,
      "memory": 1024,
      "runtime": "nodejs20.x"
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Credentials", "value": "true" },
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "*" }
      ]
    }
  ]
}
